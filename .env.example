# Stripe publishable key (starts with pk_test_ or pk_live_)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# URL of the Cloudflare Worker that creates Checkout Sessions
VITE_CHECKOUT_API_URL=https://seqrets-checkout.YOUR_SUBDOMAIN.workers.dev

# URL of the Cloudflare Worker that captures waitlist signups
VITE_WAITLIST_API_URL=https://seqrets-waitlist.YOUR_SUBDOMAIN.workers.dev
